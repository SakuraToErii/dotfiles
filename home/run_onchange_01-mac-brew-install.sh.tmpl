{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -e

brew update --quiet
brew bundle --file=/dev/stdin --quiet <<EOF
{{ range $profile := .packageProfiles -}}
{{ range index $.packages.darwin.taps $profile -}}
tap {{ . | quote }}
{{ end -}}
{{ range index $.packages.darwin.brews $profile -}}
brew {{ . | quote }}
{{ end -}}
{{ range index $.packages.darwin.casks $profile -}}
cask {{ . | quote }}
{{ end -}}
{{ end -}}
EOF
{{ end -}}
